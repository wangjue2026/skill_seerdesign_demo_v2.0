                            </ul>
                        </div>
                    </div>
                </div>

                <!-- 💻 ================= Tab 3: Vue 实时源码 ================= -->
                <div v-if="activeTab === 'code'" class="space-y-3 animate-in fade-in duration-200">
                    <div class="flex justify-between items-center px-1">
                        <span class="text-xs font-bold text-slate-400">Vue 单文件数据预览</span>
                        <span
                            class="text-[9px] bg-slate-900 border border-slate-800 text-emerald-500 px-1.5 py-0.5 rounded font-mono font-bold">内存实时映射中</span>
                    </div>

                    <p class="text-[10px] text-slate-400 leading-relaxed text-left">
                        下面是单文件内部 `initialComments` 的最新状态。点击右上方<b>“复制最新源码”</b>时，这些批注段会无感编织到您的 Vue 模板中，助您轻松完成数据存盘。
                    </p>

                    <!-- 源码模拟 -->
                    <div
                        class="bg-slate-950 rounded-xl p-3.5 border border-slate-850 font-mono text-[10px] text-emerald-400 overflow-x-auto space-y-1 text-left relative">
                        <div
                            class="absolute right-3 top-3 text-[9px] bg-slate-900 text-slate-500 px-1.5 py-0.5 rounded select-none">
                            VUE SFC</div>

                        <div class="text-slate-500 font-sans">&lt;script setup&gt;</div>
                        <div class="text-slate-500 font-sans">import { ref } from 'vue';</div>
                        <br>
                        <div class="text-amber-500 font-semibold">/* INTERACTION_COMMENTS_START */</div>
                        <div class="text-indigo-300 font-bold">const initialComments = [</div>
                        <div v-for="(item, index) in comments" :key="item.id" class="pl-4">
                            <span class="text-slate-400">{</span>
                            <div class="pl-4">
                                <span class="text-slate-300">id:</span> <span class="text-indigo-400">{{ item.id
                                    }},</span>
                                <br>
                                <span class="text-slate-300">title:</span> <span class="text-emerald-300">"{{ item.title
                                    }}",</span>
                                <br>
                                <span class="text-slate-300">content:</span> <span class="text-emerald-300">"{{
                                    item.content.slice(0, 30) }}...",</span>
                                <br>
                                <span class="text-slate-300">xPercent:</span> <span class="text-indigo-400">{{
                                    item.xPercent.toFixed(2) }},</span>
                                <br>
                                <span class="text-slate-300">yPercent:</span> <span class="text-indigo-400">{{
                                    item.yPercent.toFixed(2) }}</span>
                            </div>
                            <span class="text-slate-400">},</span>
                        </div>
                        <div class="text-indigo-300 font-bold">];</div>
                        <div class="text-amber-500 font-semibold">/* INTERACTION_COMMENTS_END */</div>
                        <br>
                        <div class="text-slate-500 font-sans">const commentList = ref(initialComments);</div>
                        <div class="text-slate-500 font-sans">&lt;/script&gt;</div>
                    </div>
                </div>

            </div>
        </div>


        <!-- 💾 绝对坐标打点录入 Modal -->
        <div v-if="showAddModal"
            class="fixed inset-0 bg-slate-950/60 backdrop-blur-sm flex items-center justify-center z-[10001] p-4 text-slate-800">
            <div
                class="bg-white rounded-2xl shadow-2xl border border-slate-100 p-6 w-full max-w-md animate-in fade-in zoom-in-95 duration-200">
                <div class="flex items-center gap-2 mb-4">
                    <div
                        class="w-6 h-6 rounded-full bg-indigo-600 text-white font-bold flex items-center justify-center text-xs">
                        {{ comments.length + 1 }}
                    </div>
                    <h3 class="font-black text-slate-800 text-base">建立交互逻辑标点</h3>
                </div>

                <div class="space-y-4">
                    <div
                        class="grid grid-cols-2 gap-3 text-[10px] font-mono text-slate-400 bg-slate-50 p-2.5 rounded-lg border border-slate-100">
                        <div>📍 标定 X 轴: <span class="text-indigo-600 font-bold">{{ tempXPercent.toFixed(1) }}%</span>
                        </div>
                        <div>📍 标定 Y 轴: <span class="text-indigo-600 font-bold">{{ tempYPercent.toFixed(1) }}%</span>
                        </div>
                    </div>

                    <div class="space-y-1">
                        <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider">交互控制点
                            (标题)</label>
                        <input v-model="newCommentTitle" type="text" placeholder="如: 解除绑定二次强校验机制"
                            class="w-full text-xs border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                    </div>

                    <div class="space-y-1">
                        <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider">交互逻辑说明 (Case
                            1-10 规范格式)</label>
                        <textarea v-model="newCommentContent" rows="4"
                            placeholder="Case 1-1: 鼠标悬浮时触发...\nCase 1-2: 弹出二次确认安全警告框..."
                            class="w-full text-xs border border-slate-200 rounded-lg px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-indigo-500"></textarea>
                    </div>
                </div>

                <div class="flex justify-end gap-2.5 mt-6">
                    <button @click="cancelDotPlacement"
                        class="px-4 py-2.5 text-xs font-bold text-slate-500 bg-slate-100 hover:bg-slate-200 rounded-lg transition">
                        取消标定
                    </button>
                    <button @click="submitNewDot"
                        class="px-4 py-2.5 text-xs font-bold text-white bg-indigo-600 hover:bg-indigo-700 rounded-lg transition shadow-md shadow-indigo-200">
                        保存标点
                    </button>
                </div>
            </div>
        </div>

    </div>

    <script>
        const { createApp, ref, computed, onMounted } = Vue;

        createApp({
            setup() {
                // --- SASE 原型数据 ---
                const selectedNodeId = ref('3');
                const searchTreeQuery = ref('');
                const searchTableQuery = ref('');
                const toastMsg = ref('');

                const treeNodes = ref([
                    { id: '1', name: '全网终端用户', count: 18, level: 0 },
                    { id: '2', name: '北京总部办公区', count: 12, level: 1 },
                    { id: '3', name: '└─ 研发安全中心', count: 6, level: 2 },
                    { id: '4', name: '└─ 运维应急响应组', count: 3, level: 2 },
                ]);

                const tableData = ref([
                    { id: 1, name: '张伟 (Senior SecOps)', email: 'zhangwei@sec.company.com', ip: '10.220.31.42', device: 'MacBook Pro 16 (macOS 14)', mfa: true, compliance: 'compliant', gateways: ['北京联通网关'] },
                    { id: 2, name: '李娜 (DBA Lead)', email: 'lina.ops@sec.company.com', ip: '10.220.12.89', device: 'ThinkPad T14s (Windows 11)', mfa: true, compliance: 'compliant', gateways: ['阿里云专用通道'] },
                    { id: 3, name: '王强 (Junior Developer)', email: 'wangqiang@sec.company.com', ip: '192.168.4.155', device: 'Ubuntu workstation 22.04', mfa: false, compliance: 'warning', gateways: ['公有云准入边缘'] },
                ]);

                const filteredTreeNodes = computed(() => {
                    if (!searchTreeQuery.value) return treeNodes.value;
                    return treeNodes.value.filter(n => n.name.includes(searchTreeQuery.value));
                });

                const filteredTableData = computed(() => {
                    if (!searchTableQuery.value) return tableData.value;
                    const query = searchTableQuery.value.toLowerCase();
                    return tableData.value.filter(u => u.name.toLowerCase().includes(query) || u.ip.includes(query));
                });

                const activeNodeName = computed(() => {
                    const node = treeNodes.value.find(n => n.id === selectedNodeId.value);
                    return node ? node.name.replace('└─ ', '') : '未指定部门';
                });

                const triggerDemoAction = (action) => {
                    showToast(`已触发 Demo 原生逻辑: [${action}]`);
                };

                const showToast = (msg) => {
                    toastMsg.value = msg;
                    setTimeout(() => { toastMsg.value = ''; }, 3500);
                };


                // --- 核心双向数据绑定交互说明引擎 ---
                const isSidebarOpen = ref(true);
                const activeTab = ref('spec');
                const showAnnotateMode = ref('full'); // full / hidden
                const isPlacingDot = ref(false);

                // 📌 这是一个真实的初始数据数组，也是被回写源码的目标
                const comments = ref([
                    {
                        id: 1,
                        title: 'SASE 客户端在线心跳',
                        content: 'Case 1-1: 客户端状态采用 WebSocket 保持3秒探针心跳。\nCase 1-2: 处于异常阻断时优先触发日志拦截。',
                        xPercent: 24.5,
                        yPercent: 24.2
                    },
                    {
                        id: 2,
                        title: 'MFA 强制校验断联',
                        content: 'Case 2-1: 识别到处于“未绑定/脱失校验”的特权人员，列表对应整行自动追加淡红背景警示。\nCase 2-2: 操作“解除绑定”时，必须联动零信任中心拉起高频验证流程。',
                        xPercent: 51.5,
                        yPercent: 53.2
                    }
                ]);

                const mouseX = ref(0);
                const mouseY = ref(0);
                const tempXPercent = ref(0);
                const tempYPercent = ref(0);
                const showAddModal = ref(false);
                const newCommentTitle = ref('');
                const newCommentContent = ref('');

                const tabs = ref([
                    { id: 'spec', name: '📋 交互说明' },
                    { id: 'rules', name: '📚 统一业务语言' },
                    { id: 'code', name: '💻 源码数据' }
                ]);

                const specRules = ref({
                    "SaseUserTable": {
                        "component_name": "零信任控制列表",
                        "must_have_cases": [
                            "在线/断联心跳异常（MFA 校验脱准机制）",
                            "用户解除绑定、强制隔离的二次重申与多端下线广播",
                            "设备指纹不合规时的警告气泡与策略联动阻断"
                        ]
                    }
                });

                const toggleSidebar = () => {
                    isSidebarOpen.value = !isSidebarOpen.value;
                    showToast(isSidebarOpen.value ? '控制台已展开' : '控制台已折叠，高保真评审预览激活');
                };

                const toggleAnnotations = () => {
                    showAnnotateMode.value = (showAnnotateMode.value === 'hidden' ? 'full' : 'hidden');
                    showToast(showAnnotateMode.value === 'full' ? '💡 交互点位已全局展示' : '🔇 交互点位已隐藏，沉浸体验原生 Demo');
                };

                const enterPlacementMode = () => {
                    isPlacingDot.value = true;
                    showToast('请在左侧区域【任意坐标位置】点击打点');
                };

                const handleGridMouseMove = (e) => {
                    const container = document.getElementById('sase-app-viewport');
                    if (!container) return;
                    const rect = container.getBoundingClientRect();
                    mouseX.value = e.clientX - rect.left;
                    mouseY.value = e.clientY - rect.top;
                    tempXPercent.value = Math.max(0, Math.min(100, (mouseX.value / rect.width) * 100));
                    tempYPercent.value = Math.max(0, Math.min(100, (mouseY.value / rect.height) * 100));
                };

                const handleGridClick = () => {
                    isPlacingDot.value = false;
                    newCommentTitle.value = '';
                    newCommentContent.value = '';
                    showAddModal.value = true;
                };

                const cancelDotPlacement = () => {
                    showAddModal.value = false;
                    showToast('已取消坐标标定');
                };

                const submitNewDot = () => {
                    if (!newCommentTitle.value || !newCommentContent.value) {
                        showToast('⚠️ 标题与说明皆为必填项');
                        return;
                    }
                    comments.value.push({
                        id: comments.value.length > 0 ? Math.max(...comments.value.map(c => c.id)) + 1 : 1,
                        title: newCommentTitle.value,
                        content: newCommentContent.value,
                        xPercent: tempXPercent.value,
                        yPercent: tempYPercent.value
                    });
                    showAnnotateMode.value = 'full';
                    showAddModal.value = false;
                    showToast(`成功标定 Case ${comments.value.length}！数据已写入运行内存。`);
                };

                const deleteComment = (index) => {
                    comments.value.splice(index, 1);
                    showToast('批注已删除，最新源码数据已重写');
                };

                // 🌟 ================== 核心创新：自研单文件全模板热重构机制 ==================
                // 这个方法模拟了内置在 .vue 文件底部的“一键自我代码重写与复制代码”逻辑
                const copyAndSaveSource = () => {
                    // 下面模拟了当前 .vue 文件的整套纯文本模板
                    const mockVueTemplate = `
<template>
  <div class="relative w-full h-full">
    <!-- 业务 UI 原型区 -->
    <SaseConsole />
    <!-- 极简批注控制条 -->
    <InteractiveComment v-model="commentList" />
  </div>
</template>

<script setup>
import { ref } from 'vue';
import InteractiveComment from './components/InteractiveComment.vue';

/* INTERACTION_COMMENTS_START */
const initialComments = ${JSON.stringify(comments.value, null, 2)};
/* INTERACTION_COMMENTS_END */

const commentList = ref(initialComments);
<\/script>
          `.trim();

                    // 写入系统剪贴板
                    const textarea = document.createElement('textarea');
                    textarea.value = mockVueTemplate;
                    document.body.appendChild(textarea);
                    textarea.select();
                    document.execCommand('copy');
                    document.body.removeChild(textarea);

                    showToast('💾 成功！最新数据已安全注入，完整 Vue 源码已复制！请在 IDE 中 Ctrl+A & Ctrl+V 保存即可！');
                };

                // 复制交付 Markdown
                const copyMarkdown = () => {
                    let md = `# SASE 零信任安全控制台 交互说明交付书\n\n`;
                    comments.value.forEach((c, idx) => {
                        md += `### 📝 Case ${idx + 1}: ${c.title}\n`;
                        md += `- **标定坐标**: (X: ${c.xPercent.toFixed(1)}%, Y: ${c.yPercent.toFixed(1)}%)\n`;
                        md += `- **交互规则详情**:\n  ${c.content.replace(/\n/g, '\n  ')}\n\n`;
                    });

                    const textarea = document.createElement('textarea');
                    textarea.value = md;
                    document.body.appendChild(textarea);
                    textarea.select();
                    document.execCommand('copy');
                    document.body.removeChild(textarea);

                    showToast('📋 Markdown 规范说明已完美复制至剪贴板，可直接在飞书/PRD中粘贴！');
                };

                return {
                    selectedNodeId,
                    searchTreeQuery,
                    searchTableQuery,
                    treeNodes,
                    tableData,
                    filteredTreeNodes,
                    filteredTableData,
                    activeNodeName,
                    triggerDemoAction,
                    toastMsg,

                    isSidebarOpen,
                    activeTab,
                    showAnnotateMode,
                    isPlacingDot,
                    comments,
                    tabs,
                    specRules,

                    mouseX,
                    mouseY,
                    tempXPercent,
                    tempYPercent,
                    showAddModal,
                    newCommentTitle,
                    newCommentContent,

                    toggleSidebar,
                    toggleAnnotations,
                    enterPlacementMode,
                    handleGridMouseMove,
                    handleGridClick,
                    cancelDotPlacement,
                    submitNewDot,
                    deleteComment,
                    copyAndSaveSource,
                    copyMarkdown
                };
            }
        }).mount('#app');
    </script>
</body>

</html>